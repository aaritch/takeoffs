{
  "name": "@takeoff/web",
  "version": "0.0.0",
  "private": true,
  "description": "Application plane: Next.js UI + synchronous API (Vercel). Next wiring lands in P0-05; for now this holds the framework-agnostic server domain (data layer, accounts module).",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/data/migrate.ts",
    "db:seed": "tsx server/data/seed.ts",
    "db:bootstrap": "tsx server/data/bootstrap-db.ts",
    "db:check": "tsx server/data/neon-check.ts",
    "db:verify-role": "tsx server/data/verify-app-role.ts",
    "redis:check": "tsx server/redis/redis-check.ts",
    "db:studio": "drizzle-kit studio",
    "storage:check": "tsx server/storage/cli.ts check",
    "storage:setup-cors": "tsx server/storage/cli.ts setup-cors"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.726.1",
    "@takeoff/auth": "workspace:*",
    "@takeoff/contracts": "workspace:*",
    "@takeoff/geometry": "workspace:*",
    "@takeoff/observability": "workspace:*",
    "@takeoff/ui": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.9"
  }
}
