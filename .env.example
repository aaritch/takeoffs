# =============================================================================
# Takeoff Platform — environment variable reference (.env.example)
# -----------------------------------------------------------------------------
# Copy to `.env` (or `.env.local` for Next.js) and fill in real values locally.
# NEVER commit real secrets. In hosted environments these are set in the Vercel
# project (app plane) and in the Phase-2 compute host (workers / AI / realtime).
# Variables are grouped by concern and annotated with the phase that first needs
# them. Values shown are placeholders / formats, not real credentials.
# =============================================================================

# --- General / app -----------------------------------------------------------
NODE_ENV=development                     # development | test | production
APP_BASE_URL=http://localhost:3000       # public origin of the Next.js app
LOG_LEVEL=info                           # trace | debug | info | warn | error

# --- Database: Neon Postgres + PostGIS (Phase 0) -----------------------------
# Pooled connection for serverless/app runtime; unpooled for migrations & workers.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL_UNPOOLED=postgres://USER:PASSWORD@HOST/DB?sslmode=require
# Optional throwaway DB used by migration tooling to diff schema.
SHADOW_DATABASE_URL=

# --- Cache / job state: Upstash Redis (Phase 0) ------------------------------
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
UPSTASH_REDIS_REST_URL=https://HOST.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Object storage: Vercel Blob (default) or S3-compatible (Phase 1) --------
BLOB_READ_WRITE_TOKEN=                   # Vercel Blob token
# If using an S3-compatible bucket instead of Vercel Blob:
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Auth: OIDC / OAuth2 identity provider (Phase 0) -------------------------
AUTH_ISSUER_URL=                         # provider issuer / discovery base URL
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_AUDIENCE=                           # expected token audience
AUTH_JWKS_URL=                           # JWKS endpoint for token verification
AUTH_REDIRECT_URL=http://localhost:3000/api/auth/callback
SESSION_SECRET=                          # signing secret for app sessions/cookies

# --- Message broker / background queue (Phase 1) -----------------------------
# Heavy work is enqueued by the app and drained by external workers (never run
# inline in a Vercel function). May reuse REDIS_URL for a Redis-backed queue.
QUEUE_URL=

# --- Realtime gateway (Phase 1) ----------------------------------------------
# Persistent WebSocket service runs OFF Vercel (Phase-2 compute host).
REALTIME_GATEWAY_URL=ws://localhost:3001
REALTIME_GATEWAY_AUTH_SECRET=

# --- Tiles / CDN (Phase 1) ---------------------------------------------------
TILES_BASE_URL=                          # CDN/base URL serving the tile pyramid

# --- AI inference & model registry (Phase 2) ---------------------------------
AI_INFERENCE_URL=                        # FastAPI inference service base URL
AI_INFERENCE_API_KEY=
MODEL_REGISTRY_URL=
MODEL_REGISTRY_TOKEN=

# --- Search (later) ----------------------------------------------------------
SEARCH_URL=                              # OpenSearch/Elasticsearch (Postgres FTS early)

# --- Payments: Stripe (Phase 4) ----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=                # marketplace payouts (Connect)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email: transactional provider (Phase 0+) --------------------------------
EMAIL_API_KEY=
EMAIL_FROM="Takeoff Platform <no-reply@example.com>"

# --- Observability (Phase 0) -------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=             # OpenTelemetry collector endpoint
SENTRY_DSN=                              # optional error tracking

# --- Client-exposed values (must be prefixed NEXT_PUBLIC_) -------------------
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
