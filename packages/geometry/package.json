    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@takeoff/contracts": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
